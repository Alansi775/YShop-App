<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>API_BASE_HOST</key>
	<string>http://192.168.1.94:3000</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>YSHOP_TTS_KEY</key>
	<string>$(YSHOP_TTS_KEY)</string>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>
	<key>NSMicrophoneUsageDescription</key>
	<string>YShop AI Assistant uses your microphone to understand voice requests</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>YShop AI Assistant converts your voice to text to answer shopping questions</string>
	<key>NSCameraUsageDescription</key>
	<string>YSHOP needs camera access to scan the store QR code for pickup verification</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>YSHOP needs your location for delivery tracking</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>YSHOP needs your location to set your delivery address</string>
</dict>
</plist>
